<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>AGI Network</title>
<link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --gold:#F5C518;--red:#2F6FED;--red-dark:#1F4FC0;
  --bg:#F3F4F6;--card:#FFFFFF;--ink:#1A1D26;--muted:#7A8094;
  --green:#1FAF5C;--blue:#2F6FED;--purple:#7C5CFC;
  --nav:64px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html,body{width:100%;overflow-x:hidden;}
body{font-family:'Cairo',sans-serif;background:var(--bg);color:var(--ink);padding-bottom:var(--nav);}

.topbar{position:sticky;top:0;z-index:100;background:var(--bg);display:flex;align-items:center;justify-content:space-between;padding:10px 14px;}
.tb-x{width:34px;height:34px;border-radius:50%;background:#E3E5EA;display:flex;align-items:center;justify-content:center;font-size:16px;color:var(--muted);cursor:pointer;flex-shrink:0;}
.tb-pill{flex:1;margin:0 10px;background:var(--ink);color:#fff;border-radius:30px;height:38px;display:flex;align-items:center;justify-content:center;gap:7px;font-size:14px;font-weight:700;}
.tb-dot{width:8px;height:8px;border-radius:50%;background:var(--red);}
.tb-r{display:flex;align-items:center;gap:6px;}
.tb-btn{width:34px;height:34px;border-radius:50%;background:#E3E5EA;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--ink);cursor:pointer;flex-shrink:0;}

.cnt{padding:14px;}
.page{display:none;}
.page.active{display:block;animation:fi .2s ease;}
@keyframes fi{from{opacity:0;transform:translateY(6px);}to{opacity:1;transform:translateY(0);}}

.welcome-card{background:var(--card);border-radius:18px;padding:18px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);display:flex;align-items:center;gap:14px;}
.welcome-text{flex:1;}
.welcome-hi{font-size:17px;font-weight:800;margin-bottom:3px;}
.welcome-sub{font-size:12px;color:var(--muted);}
.welcome-icon{width:54px;height:54px;border-radius:50%;background:radial-gradient(circle,#fff,#e8f5ed);display:flex;align-items:center;justify-content:center;font-size:26px;border:2px dashed var(--green);flex-shrink:0;}

.bal-row{background:var(--card);border-radius:18px;padding:16px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);display:flex;align-items:center;justify-content:space-between;}
.bal-left{display:flex;align-items:center;gap:10px;}
.bal-icon{width:30px;height:30px;border-radius:50%;background:linear-gradient(135deg,var(--red),var(--red-dark));display:flex;align-items:center;justify-content:center;font-size:14px;color:#fff;}
.bal-label{font-size:11px;color:var(--muted);}
.bal-val{font-size:18px;font-weight:800;}
.bal-usd{font-size:11px;color:var(--green);}
.status-badge{display:flex;align-items:center;gap:5px;background:rgba(31,175,92,.12);color:var(--green);font-size:12px;font-weight:700;padding:5px 12px;border-radius:20px;}
.status-dot{width:7px;height:7px;border-radius:50%;background:var(--green);animation:pu 1.5s infinite;}
@keyframes pu{0%,100%{opacity:1;transform:scale(1);}50%{opacity:.5;transform:scale(1.4);}}

.mine-panel{background:linear-gradient(160deg,var(--red),var(--red-dark));border-radius:20px;padding:18px;margin-bottom:14px;color:#fff;box-shadow:0 6px 20px rgba(232,57,43,.25);}
.mine-row{display:flex;justify-content:space-between;margin-bottom:14px;}
.mine-stat{flex:1;}
.mine-stat-lb{font-size:11px;opacity:.85;margin-bottom:3px;display:flex;align-items:center;gap:5px;}
.mine-stat-v{font-size:16px;font-weight:800;}
.mine-stat-d{font-size:10px;opacity:.85;margin-top:2px;}
.mine-divider{width:1px;background:rgba(255,255,255,.25);margin:0 12px;}
.mine-active-box{background:rgba(255,255,255,.12);border-radius:14px;padding:12px 14px;margin-bottom:12px;}
.mine-active-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;}
.mine-active-lb{font-size:12px;font-weight:700;display:flex;align-items:center;gap:6px;}
.mine-active-time{font-size:13px;font-weight:800;font-family:monospace;}
.mine-prog-bg{height:6px;background:rgba(255,255,255,.25);border-radius:6px;overflow:hidden;}
.mine-prog-bar{height:100%;background:#fff;border-radius:6px;transition:width 1s linear;}
.mine-bottom{display:flex;justify-content:space-between;align-items:center;}
.mine-earned-lb{font-size:11px;opacity:.85;display:flex;align-items:center;gap:5px;}
.mine-earned-v{font-size:15px;font-weight:800;}
.mine-energy-lb{font-size:11px;opacity:.85;text-align:left;}
.mine-energy-v{font-size:13px;font-weight:800;text-align:left;}

.two-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:14px;}
.mini-card{background:var(--card);border-radius:16px;padding:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);}
.mini-icon{width:34px;height:34px;border-radius:9px;display:flex;align-items:center;justify-content:center;font-size:17px;margin-bottom:10px;}
.mini-icon.blue{background:rgba(47,111,237,.1);color:var(--blue);}
.mini-icon.red{background:rgba(232,57,43,.1);color:var(--red);}
.mini-lb{font-size:12px;color:var(--muted);margin-bottom:3px;}
.mini-val{font-size:16px;font-weight:800;margin-bottom:10px;}
.mini-btn{width:100%;height:34px;border-radius:10px;font-family:'Cairo',sans-serif;font-size:12px;font-weight:700;cursor:pointer;border:none;display:flex;align-items:center;justify-content:center;gap:5px;}
.mini-btn.start{background:var(--blue);color:#fff;}
.mini-btn.start:disabled{background:#C9D3E8;}
.mini-btns-row{display:flex;gap:6px;}
.mini-btn-sm{flex:1;height:30px;border-radius:9px;font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;border:none;display:flex;align-items:center;justify-content:center;gap:4px;}
.mini-btn-sm.invite{background:rgba(47,111,237,.1);color:var(--blue);}
.mini-btn-sm.copy{background:rgba(232,57,43,.1);color:var(--red);}

.gold-btn{width:100%;height:50px;border-radius:16px;background:linear-gradient(135deg,var(--gold),#D9A800);color:#1a1100;font-family:'Cairo',sans-serif;font-size:15px;font-weight:800;cursor:pointer;border:none;margin-bottom:14px;box-shadow:0 4px 14px rgba(245,197,24,.3);}

.sec-title{font-size:14px;font-weight:800;margin-bottom:10px;display:flex;align-items:center;gap:6px;}
.chip-row{display:flex;gap:7px;margin-bottom:14px;overflow-x:auto;padding-bottom:2px;}
.chip{flex-shrink:0;padding:7px 16px;border-radius:20px;background:var(--card);color:var(--ink);font-size:12px;font-weight:700;cursor:pointer;border:1px solid #E3E5EA;}
.chip.active{background:var(--red);color:#fff;border-color:var(--red);}

.task-card{background:var(--card);border-radius:14px;padding:14px;margin-bottom:8px;display:flex;align-items:center;gap:12px;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.task-ic{width:42px;height:42px;border-radius:11px;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.task-info{flex:1;}
.task-t{font-size:13px;font-weight:700;}
.task-r{font-size:11px;color:var(--green);font-weight:700;margin-top:2px;}
.task-go{width:32px;height:32px;border-radius:50%;background:#F0F1F4;display:flex;align-items:center;justify-content:center;font-size:14px;color:var(--muted);cursor:pointer;}

.wallet-balance-card{background:var(--card);border-radius:18px;padding:20px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);}
.wb-top{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px;}
.wb-lb{font-size:12px;color:var(--muted);margin-bottom:2px;}
.wb-val{font-size:26px;font-weight:900;}
.wb-usd{font-size:12px;color:var(--green);}
.wb-icon{width:42px;height:42px;border-radius:11px;background:rgba(47,111,237,.1);display:flex;align-items:center;justify-content:center;font-size:20px;}
.wb-actions{display:flex;gap:10px;}
.wb-btn{flex:1;height:44px;border-radius:12px;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;border:none;display:flex;align-items:center;justify-content:center;gap:6px;}
.wb-btn.send{background:var(--blue);color:#fff;}
.wb-btn.recv{background:#EEF0F4;color:var(--ink);}

.send-card{background:var(--card);border-radius:16px;padding:16px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.06);}
.send-title{font-size:13px;font-weight:800;margin-bottom:12px;display:flex;align-items:center;gap:6px;}
.send-field{background:#F3F4F6;border-radius:12px;padding:12px 14px;margin-bottom:10px;display:flex;align-items:center;gap:10px;}
.send-field input{flex:1;background:transparent;border:none;outline:none;font-family:'Cairo',sans-serif;font-size:13px;color:var(--ink);}
.max-btn{font-size:11px;color:var(--blue);font-weight:800;cursor:pointer;background:rgba(47,111,237,.08);padding:4px 10px;border-radius:8px;}
.send-confirm{width:100%;height:46px;border-radius:13px;background:var(--blue);color:#fff;font-family:'Cairo',sans-serif;font-size:14px;font-weight:800;cursor:pointer;border:none;}
.tx-empty{background:var(--card);border-radius:16px;padding:30px;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.06);}

.staking-empty{background:var(--card);border-radius:20px;padding:40px 24px;text-align:center;box-shadow:0 1px 3px rgba(0,0,0,.06);margin-top:40px;}
.staking-icon{width:70px;height:70px;border-radius:18px;background:rgba(124,92,252,.1);display:flex;align-items:center;justify-content:center;font-size:34px;margin:0 auto 16px;}
.staking-title{font-size:17px;font-weight:800;margin-bottom:8px;}
.staking-desc{font-size:13px;color:var(--muted);line-height:1.6;}

.profile-field{background:var(--card);border-radius:14px;padding:16px;margin-bottom:10px;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.profile-field-lb{font-size:11px;color:var(--muted);margin-bottom:4px;}
.profile-field-v{font-size:15px;font-weight:800;}
.reward-card{background:linear-gradient(135deg,var(--red),#F0556B);border-radius:14px;padding:16px;margin-bottom:10px;color:#fff;display:flex;align-items:center;gap:12px;}
.reward-ic{font-size:30px;}
.reward-t{font-size:13px;font-weight:800;}
.reward-s{font-size:11px;opacity:.9;margin-top:2px;}
.row-item{background:var(--card);border-radius:14px;padding:15px 16px;margin-bottom:8px;box-shadow:0 1px 3px rgba(0,0,0,.05);display:flex;align-items:center;gap:12px;cursor:pointer;}
.row-icon{font-size:18px;width:24px;text-align:center;}
.row-label{flex:1;font-size:13px;font-weight:700;}
.row-arrow{color:var(--muted);font-size:14px;}
.toggle{width:42px;height:24px;border-radius:14px;background:var(--blue);position:relative;cursor:pointer;flex-shrink:0;}
.toggle-dot{width:18px;height:18px;border-radius:50%;background:#fff;position:absolute;top:3px;right:21px;transition:right .2s;}
.toggle.off{background:#D7DAE0;}
.toggle.off .toggle-dot{right:3px;}
.close-app{color:var(--red);}

.earn-tabs{display:flex;background:var(--card);border-radius:14px;padding:4px;gap:3px;margin-bottom:14px;box-shadow:0 1px 3px rgba(0,0,0,.05);}
.earn-tab{flex:1;padding:9px 4px;border-radius:11px;text-align:center;font-size:11px;font-weight:700;cursor:pointer;color:var(--muted);}
.earn-tab.active{background:var(--red);color:#fff;}
.ad-card{display:flex;align-items:center;gap:12px;padding:13px;background:var(--card);border-radius:14px;margin-bottom:8px;box-shadow:0 1px 3px rgba(0,0,0,.05);text-decoration:none;color:var(--ink);}
.ad-th{width:44px;height:44px;border-radius:11px;background:#F3F4F6;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.ad-i{flex:1;}
.ad-t{font-size:13px;font-weight:700;}
.ad-d{font-size:11px;color:var(--muted);}
.ad-r{font-size:11px;color:var(--green);font-weight:700;margin-top:3px;}
.ad-btn{height:32px;padding:0 14px;border-radius:9px;background:var(--red);color:#fff;font-family:'Cairo',sans-serif;font-size:11px;font-weight:700;cursor:pointer;border:none;white-space:nowrap;}

.bnav{position:fixed;bottom:0;left:0;right:0;z-index:200;background:var(--card);box-shadow:0 -2px 12px rgba(0,0,0,.06);display:flex;height:var(--nav);}
.bni{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:3px;cursor:pointer;color:var(--muted);position:relative;}
.bni.active{color:var(--red);}
.bni-ic{font-size:20px;line-height:1;}
.bni-lb{font-size:10px;font-weight:700;}
.bni-bd{position:absolute;top:2px;right:calc(50% - 16px);background:var(--red);color:#fff;font-size:9px;font-weight:800;min-width:16px;height:16px;border-radius:10px;display:flex;align-items:center;justify-content:center;}

.mo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.5);z-index:300;align-items:flex-end;}
.mo.open{display:flex;}
.md{background:var(--card);border-radius:22px 22px 0 0;padding:22px;width:100%;max-height:88vh;overflow-y:auto;}
.md-t{font-size:16px;font-weight:800;margin-bottom:16px;}
.ig{margin-bottom:12px;}
.il{font-size:11px;color:var(--muted);font-weight:700;margin-bottom:6px;}
.ii{width:100%;background:#F3F4F6;border:none;border-radius:11px;padding:12px 14px;color:var(--ink);font-family:'Cairo',sans-serif;font-size:14px;outline:none;}
.mf{display:flex;gap:8px;margin-top:14px;}
.btn{height:44px;padding:0 16px;border-radius:12px;font-family:'Cairo',sans-serif;font-size:13px;font-weight:700;cursor:pointer;border:none;flex:1;}
.btn-r{background:var(--red);color:#fff;}
.btn-o{background:#F0F1F4;color:var(--ink);}
.addr-box{background:#FFF8E1;border:1px solid #F5D67A;border-radius:12px;padding:14px;margin-bottom:14px;text-align:center;}
.addr-box-lb{font-size:11px;color:#8A6D00;margin-bottom:8px;font-weight:700;}
.addr-box-val{font-family:monospace;font-size:11px;color:#5C4400;word-break:break-all;background:rgba(245,197,24,.15);padding:10px;border-radius:8px;}
.addr-copy{margin-top:10px;height:32px;padding:0 16px;border-radius:9px;background:var(--gold);color:#1a1100;font-family:'Cairo',sans-serif;font-size:12px;font-weight:800;cursor:pointer;border:none;}

.vo{display:none;position:fixed;inset:0;background:rgba(0,0,0,.92);z-index:400;flex-direction:column;align-items:center;justify-content:center;gap:16px;}
.vo.open{display:flex;}
.vs{width:88vw;height:48vw;max-height:200px;background:var(--card);border-radius:16px;display:flex;align-items:center;justify-content:center;font-size:44px;}
.vt{font-size:38px;font-weight:900;color:var(--gold);}
.sk{height:42px;padding:0 26px;border-radius:12px;background:var(--gold);color:#1a1100;font-family:'Cairo',sans-serif;font-size:14px;font-weight:800;cursor:pointer;border:none;opacity:.4;pointer-events:none;}
.sk.rdy{opacity:1;pointer-events:all;}

.toast{position:fixed;bottom:78px;left:50%;transform:translateX(-50%);background:var(--ink);color:#fff;border-radius:12px;padding:11px 20px;font-size:13px;font-weight:700;z-index:500;opacity:0;transition:opacity .3s;pointer-events:none;white-space:nowrap;}
.toast.show{opacity:1;}
::-webkit-scrollbar{width:0;height:0;}
</style>
</head>
<body>

<div class="topbar">
  <div class="tb-x">✕</div>
  <div class="tb-pill"><span class="tb-dot"></span><span id="tbTitle">AGI Network</span></div>
  <div class="tb-r"><div class="tb-btn">⌄</div><div class="tb-btn">⋮</div></div>
</div>

<div class="cnt">

<div class="page active" id="page-home">
  <div class="welcome-card">
    <div class="welcome-text"><div class="welcome-hi">👋 أهلاً، Eidmo11!</div><div class="welcome-sub">مرحباً بك في بوت تعدين AGI Network</div></div>
    <div class="welcome-icon">🤖</div>
  </div>
  <div class="bal-row">
    <div class="bal-left">
      <div class="bal-icon">⛏️</div>
      <div><div class="bal-label">إجمالي الرصيد</div><div class="bal-val" id="balVal">0.00 AGI</div><div class="bal-usd" id="balUsd">≈ $0.00 USD</div></div>
    </div>
    <div class="status-badge"><span class="status-dot"></span><span id="statusText">نشط</span></div>
  </div>

  <div class="mine-panel">
    <div class="mine-row">
      <div class="mine-stat">
        <div class="mine-stat-lb">⏱ معدل التعدين</div>
        <div class="mine-stat-v">0.0083 AGI/س</div>
        <div class="mine-stat-d">+0% عن الأسبوع الماضي</div>
      </div>
      <div class="mine-divider"></div>
      <div class="mine-stat" style="text-align:left">
        <div class="mine-stat-lb" style="justify-content:flex-end">⚡ قوة التعدين</div>
        <div class="mine-stat-v">24 GH/s</div>
        <div class="mine-stat-d">+0% عن الأسبوع الماضي</div>
      </div>
    </div>
    <div class="mine-active-box">
      <div class="mine-active-top"><div class="mine-active-lb"><span class="status-dot" style="background:#fff"></span> جاري التعدين...</div><div class="mine-active-time" id="mineTimeLeft">12:00:00</div></div>
      <div class="mine-prog-bg"><div class="mine-prog-bar" id="mineProgBar" style="width:0%"></div></div>
    </div>
    <div class="mine-bottom">
      <div><div class="mine-earned-lb">🪙 الرموز المكتسبة</div><div class="mine-earned-v" id="earnedVal">0.0000 AGI</div></div>
      <div><div class="mine-energy-lb">⚡ الطاقة</div><div class="mine-energy-v" id="energyVal">100 / 100</div></div>
    </div>
  </div>

  <div class="two-grid">
    <div class="mini-card">
      <div class="mini-icon blue">⛏️</div><div class="mini-lb">جلسة التعدين</div><div class="mini-val" id="sessionStatus">متوقفة</div>
      <button class="mini-btn start" id="mineBtn" onclick="startMining()">▶ بدء التعدين</button>
    </div>
    <div class="mini-card">
      <div class="mini-icon red">👥</div><div class="mini-lb">إجمالي الإحالات</div>
      <div class="mini-val"><span id="teamCount">0</span> · <span id="refBonus" style="color:var(--green)">0 AGI</span></div>
      <div class="mini-btns-row"><button class="mini-btn-sm invite" onclick="go('referral')">+ دعوة</button><button class="mini-btn-sm copy" onclick="copyRef()">📋 نسخ</button></div>
    </div>
  </div>

  <button class="gold-btn" onclick="go('earn')">🚀 ابدأ في كسب المزيد من AGI</button>

  <div style="background:var(--card);border-radius:14px;padding:12px;text-align:center;margin-bottom:14px;border:1px dashed #D7DAE0">
    <div style="font-size:10px;color:var(--muted)">— مساحة إعلانية —</div>
    <div style="font-size:11px;color:var(--muted);margin-top:4px">ستظهر إعلانات حقيقية بعد تفعيل AdSense</div>
  </div>
</div>

<div class="page" id="page-tasks">
  <div class="sec-title">📋 مركز المهام</div>
  <div id="requiredBox" style="background:#FFF4E5;border:2px solid var(--gold);border-radius:14px;padding:14px;margin-bottom:14px">
    <div style="font-size:13px;font-weight:800;margin-bottom:4px">⚠️ اشتراك إلزامي قبل السحب</div>
    <div style="font-size:11px;color:var(--muted);margin-bottom:10px">يجب الاشتراك في القناتين التاليتين لتفعيل السحب من حسابك</div>

    <div class="task-card" style="margin-bottom:8px" id="reqTelegram">
      <div class="task-ic" style="background:rgba(47,111,237,.1);color:var(--blue)">📩</div>
      <div class="task-info"><div class="task-t">انضم لقناة الدعم الرسمية</div><div class="task-r" id="reqTgStatus">مطلوب — لم يتم التأكيد</div></div>
      <a href="https://t.me/Free2045" target="_blank" class="task-go" style="text-decoration:none" onclick="markReq('tg')">←</a>
    </div>
    <div class="task-card" id="reqFacebook">
      <div class="task-ic" style="background:rgba(47,111,237,.15);color:#1877F2">📘</div>
      <div class="task-info"><div class="task-t">تابع صفحة فيسبوك الرسمية</div><div class="task-r" id="reqFbStatus">مطلوب — لم يتم التأكيد</div></div>
