      <button class="addr-copy" onclick="copyAddr('0xC7FA03BAE1d361401C30AAaF20333486fBe1D6b9')">📋 نسخ العنوان</button>
      <div style="font-size:10px;color:#C0392B;margin-top:10px;font-weight:700">⚠️ أرسل فقط على شبكة BEP20 (BSC) — أي شبكة أخرى = فقدان الأموال</div>
      <div style="font-size:10px;color:var(--muted);margin-top:4px">✅ USDT / BNB / BUSD على شبكة BNB Smart Chain</div>
    </div>

    <div id="tonBox" class="addr-box" style="display:none">
      <div class="addr-box-lb">📋 عنوان الإيداع — شبكة TON</div>
      <div class="addr-box-val" id="depAddrTon">UQA2CLot73qOKb_2BSmqOsUA0TzHYPuyB4QFT3G2quUcZdTg</div>
      <button class="addr-copy" onclick="copyAddr(document.getElementById('depAddrTon').textContent)">📋 نسخ العنوان</button>
      <div style="font-size:10px;color:#C0392B;margin-top:10px;font-weight:700">⚠️ أرسل فقط عملات على شبكة TON (Toncoin / Jettons) إلى هذا العنوان</div>
      <div style="font-size:10px;color:var(--muted);margin-top:4px">✅ هذه المحفظة الرئيسية لاستقبال الإيداعات على شبكة TON</div>
    </div>

    <button class="btn btn-o" style="width:100%;flex:none;margin-top:12px" onclick="closeM('mDeposit')">إغلاق</button>
  </div>
</div>


<div class="mo" id="mWithdraw" onclick="if(event.target===this)closeM('mWithdraw')">
  <div class="md">
    <div class="md-t">📤 إرسال — سحب</div>
    <div style="background:rgba(31,175,92,.1);border-radius:10px;padding:10px 13px;margin-bottom:13px;font-size:12px;color:var(--green);font-weight:700">✓ الحد الأدنى للسحب: 0.001 AGI — يُدفع يدوياً بعد موافقة المالك</div>
    <div class="ig"><div class="il">الشبكة</div>
      <select class="ii" id="wNet">
        <option value="TON">💎 TON</option>
        <option value="BEP20">🟡 BEP20 (BSC)</option>
      </select>
    </div>
    <div class="ig"><div class="il">عنوان محفظتك على الشبكة المختارة</div><input class="ii" id="wAddr" type="text" placeholder="ألصق عنوان محفظتك هنا"></div>
    <div class="ig"><div class="il">المبلغ</div><input class="ii" id="wAmt" type="number" placeholder="0.00"></div>
    <div style="font-size:10px;color:var(--muted);margin-bottom:10px">سيراجع المالك طلبك ويرسل المبلغ يدوياً إلى عنوانك أعلاه على نفس الشبكة المختارة.</div>
    <div class="mf"><button class="btn btn-r" onclick="submitWithdraw()">تأكيد السحب</button><button class="btn btn-o" onclick="closeM('mWithdraw')">إلغاء</button></div>
  </div>
</div>

<div class="vo" id="vo">
  <div class="vs">📺</div>
  <div class="vt" id="vt">15</div>
  <button class="sk" id="sk" onclick="closeVideo()">✓ احصل على المكافأة</button>
</div>

<div class="toast" id="toastEl"></div>

<script>
function generateRefCode(){
  const chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';
  let code='';
  for(let i=0;i<6;i++) code+=chars[Math.floor(Math.random()*chars.length)];
  return 'AGI-'+code;
}
function getOrCreateRefCode(){
  let code=localStorage.getItem('agi_myRefCode');
  if(!code){
    code=generateRefCode();
    localStorage.setItem('agi_myRefCode',code);
  }
  return code;
}

const ST = {
  balance: parseFloat(localStorage.getItem('agi_bal')||'0'),
  earned: parseFloat(localStorage.getItem('agi_earned')||'0'),
  mining: localStorage.getItem('agi_mining')==='1',
  mineStart: parseInt(localStorage.getItem('agi_mineStart')||'0'),
  team: parseInt(localStorage.getItem('agi_team')||'0'),
  refBonus: parseFloat(localStorage.getItem('agi_refBonus')||'0'),
  tx: JSON.parse(localStorage.getItem('agi_tx')||'[]'),
  reqTg: localStorage.getItem('agi_reqTg')==='1',
  reqFb: localStorage.getItem('agi_reqFb')==='1',
  refCode: getOrCreateRefCode(),
};
const MINE_DURATION = 12*60*60*1000;
const MINE_RATE_HOUR = 0.0083;
const USD_RATE = 1.2;

function save(){
  localStorage.setItem('agi_bal',ST.balance);
  localStorage.setItem('agi_earned',ST.earned);
  localStorage.setItem('agi_mining',ST.mining?'1':'0');
  localStorage.setItem('agi_mineStart',ST.mineStart);
  localStorage.setItem('agi_team',ST.team);
  localStorage.setItem('agi_refBonus',ST.refBonus);
  localStorage.setItem('agi_tx',JSON.stringify(ST.tx.slice(-20)));
  localStorage.setItem('agi_reqTg',ST.reqTg?'1':'0');
  localStorage.setItem('agi_reqFb',ST.reqFb?'1':'0');
}

const titles={home:'AGI Network',tasks:'مركز المهام',wallet:'محفظتي',staking:'تجمع الرهن',earn:'اكسب المزيد',referral:'الإحالة',profile:'الملف الشخصي',admin:'لوحة الإدارة',advertiser:'أعلن معنا'};
function go(id){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.getElementById('page-'+id).classList.add('active');
  document.getElementById('tbTitle').textContent=titles[id]||'AGI Network';
  document.querySelectorAll('.bni').forEach(n=>n.classList.remove('active'));
  const m={home:0,wallet:1,staking:2,tasks:3,profile:4};
  if(m[id]!==undefined) document.querySelectorAll('.bni')[m[id]].classList.add('active');
  render();
}

function startMining(){
  if(ST.mining){toast('⏳ التعدين يعمل بالفعل');return;}
  ST.mining=true;ST.mineStart=Date.now();save();
  toast('✅ بدأ التعدين! سينتهي بعد 12 ساعة');
  render();
}

function render(){
  document.getElementById('balVal').textContent=ST.balance.toFixed(4)+' AGI';
  document.getElementById('balUsd').textContent='≈ $'+(ST.balance*USD_RATE).toFixed(2)+' USD';
  document.getElementById('wbVal').textContent=ST.balance.toFixed(4)+' AGI';
  document.getElementById('wbUsd').textContent='≈ $'+(ST.balance*USD_RATE).toFixed(2);
  document.getElementById('teamCount').textContent=ST.team;
  document.getElementById('refBonus').textContent=ST.refBonus.toFixed(2)+' AGI';
  document.getElementById('refCountText').textContent=ST.team+' أصدقاء مدعوون';
  document.getElementById('refCountText2').textContent=ST.team+' أصدقاء مدعوون';
  const refLinkEl=document.getElementById('refLink');
  if(refLinkEl) refLinkEl.value=getRefUrl();
  const refCodeEl=document.getElementById('refCodeDisplay');
  if(refCodeEl) refCodeEl.textContent=ST.refCode;

  const now=Date.now();
  if(ST.mining){
    const elapsed=now-ST.mineStart;
    if(elapsed>=MINE_DURATION){
      const reward=MINE_RATE_HOUR*12;
      ST.balance+=reward;ST.earned+=reward;ST.mining=false;
      addTx('⛏️ مكافأة تعدين','+'+reward.toFixed(4)+' AGI');
      save();toast('🎉 اكتمل التعدين! +'+reward.toFixed(4)+' AGI');render();return;
    }
    const pct=(elapsed/MINE_DURATION)*100;
    const remaining=MINE_DURATION-elapsed;
    const h=Math.floor(remaining/3600000),m=Math.floor((remaining%3600000)/60000),s=Math.floor((remaining%60000)/1000);
    document.getElementById('mineTimeLeft').textContent=String(h).padStart(2,'0')+':'+String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
    document.getElementById('mineProgBar').style.width=pct+'%';
    document.getElementById('earnedVal').textContent=(MINE_RATE_HOUR*(elapsed/3600000)).toFixed(4)+' AGI';
    document.getElementById('sessionStatus').textContent='نشطة';
    document.getElementById('mineBtn').textContent='⏳ جاري التعدين...';
    document.getElementById('mineBtn').disabled=true;
    document.getElementById('statusText').textContent='يعدّن';
  } else {
    document.getElementById('mineTimeLeft').textContent='12:00:00';
    document.getElementById('mineProgBar').style.width='0%';
    document.getElementById('earnedVal').textContent='0.0000 AGI';
    document.getElementById('sessionStatus').textContent='متوقفة';
    document.getElementById('mineBtn').textContent='▶ بدء التعدين';
    document.getElementById('mineBtn').disabled=false;
    document.getElementById('statusText').textContent='نشط';
  }
  renderTx();
  checkRequired();
}

function addTx(type,amount){
  ST.tx.unshift({type,amount,date:new Date().toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit',day:'2-digit',month:'2-digit'})});
  save();
}
function renderTx(){
  const el=document.getElementById('txContainer');
  if(!el)return;
  if(ST.tx.length===0){el.innerHTML='<div class="tx-empty"><div style="font-size:32px;margin-bottom:8px;opacity:.4">📄</div><div style="color:var(--muted);font-size:13px">لا توجد معاملات حتى الآن</div></div>';return;}
  el.innerHTML=ST.tx.slice(0,15).map(t=>'<div class="task-card"><div class="task-ic" style="background:rgba(31,175,92,.1);color:var(--green)">💰</div><div class="task-info"><div class="task-t">'+t.type+'</div><div style="font-size:11px;color:var(--muted)">'+t.date+'</div></div><div style="color:var(--green);font-weight:800;font-size:13px">'+t.amount+'</div></div>').join('');
}

function filterTasks(chip,cat){
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  chip.classList.add('active');
  document.querySelectorAll('#tasksList .task-card').forEach(c=>{c.style.display=(cat==='all'||c.dataset.cat===cat)?'flex':'none';});
}

function earnTab(tab,type){
  document.querySelectorAll('.earn-tab').forEach(t=>t.classList.remove('active'));
  tab.classList.add('active');
  ['sites','video','bots'].forEach(t=>{const e=document.getElementById('earn-'+t);if(e)e.style.display=t===type?'block':'none';});
}

function markReq(which){
  setTimeout(()=>{
    if(which==='tg'){ST.reqTg=true;document.getElementById('reqTgStatus').textContent='✅ تم التأكيد';document.getElementById('reqTgStatus').style.color='var(--green)';}
    if(which==='fb'){ST.reqFb=true;document.getElementById('reqFbStatus').textContent='✅ تم التأكيد';document.getElementById('reqFbStatus').style.color='var(--green)';}
    save();
    toast('✅ تم تأكيد الاشتراك');
  },1500);
}

function checkRequired(){
  if(document.getElementById('reqTgStatus')){
    document.getElementById('reqTgStatus').textContent=ST.reqTg?'✅ تم التأكيد':'مطلوب — لم يتم التأكيد';
    document.getElementById('reqTgStatus').style.color=ST.reqTg?'var(--green)':'';
    document.getElementById('reqFbStatus').textContent=ST.reqFb?'✅ تم التأكيد':'مطلوب — لم يتم التأكيد';
    document.getElementById('reqFbStatus').style.color=ST.reqFb?'var(--green)':'';
  }
}
function renderPendingWithdrawals(){
  const el=document.getElementById('pendingWList');
  if(!el)return;
  const list=JSON.parse(localStorage.getItem('agi_pendingW')||'[]');
  if(list.length===0){el.innerHTML='<div class="tx-empty" style="margin-bottom:12px"><div style="font-size:13px;color:var(--muted)">لا توجد طلبات سحب حالياً</div></div>';return;}
  el.innerHTML=list.map(w=>`
    <div class="task-card" style="margin-bottom:8px;align-items:flex-start;flex-direction:column;gap:8px">
      <div style="display:flex;width:100%;justify-content:space-between;align-items:center">
        <div style="font-size:13px;font-weight:800">${w.amount} AGI <span style="font-size:11px;color:var(--muted);font-weight:600">(${w.network})</span></div>
        <div style="font-size:11px;font-weight:700;color:${w.status==='معلق'?'#B8860B':w.status==='مدفوع'?'var(--green)':'var(--muted)'}">${w.status}</div>
      </div>
      <div style="font-size:10px;color:var(--muted);font-family:monospace;word-break:break-all;width:100%">${w.address}</div>
      <div style="font-size:10px;color:var(--muted)">${w.date} — المستخدم: ${w.user}</div>
      ${w.status==='معلق'?`<div style="display:flex;gap:6px;width:100%">
        <button class="ad-btn" style="flex:1;background:var(--green)" onclick="approveW('${w.id}')">✅ تمت الدفعة</button>
        <button class="ad-btn" style="flex:1;background:#C0392B" onclick="rejectW('${w.id}')">❌ رفض وإرجاع</button>
      </div>`:''}
    </div>
  `).join('');
}

function approveW(id){
  const list=JSON.parse(localStorage.getItem('agi_pendingW')||'[]');
  const item=list.find(w=>w.id===id);
  if(item){item.status='مدفوع';localStorage.setItem('agi_pendingW',JSON.stringify(list));}
  renderPendingWithdrawals();
  toast('✅ تم تسجيل الطلب كمدفوع');
}

function rejectW(id){
  const list=JSON.parse(localStorage.getItem('agi_pendingW')||'[]');
  const item=list.find(w=>w.id===id);
  if(item){
    item.status='مرفوض — أُعيد للرصيد';
    // إعادة المبلغ لرصيد المستخدم الحالي (بيئة تجريبية بدون خادم)
    ST.balance+=parseFloat(item.amount);
    save();
    localStorage.setItem('agi_pendingW',JSON.stringify(list));
  }
  renderPendingWithdrawals();
  render();
  toast('↩️ تم رفض الطلب وإرجاع المبلغ للرصيد');
}

function confirmSend(){
  const r=document.getElementById('sendRecipient').value.trim();
  const a=parseFloat(document.getElementById('sendAmount').value)||0;
  if(!r){toast('❌ أدخل معرف المستلم');return;}
  if(a<=0||a>ST.balance){toast('❌ مبلغ غير صالح');return;}
  ST.balance-=a;save();addTx('✈️ إرسال إلى '+r,'-'+a.toFixed(4)+' AGI');toast('✅ تم الإرسال بنجاح');render();
}

function submitWithdraw(){
  if(!ST.reqTg || !ST.reqFb){
    closeM('mWithdraw');
    toast('❌ يجب الاشتراك في القناتين المطلوبتين أولاً (صفحة المهام)');
    go('tasks');
    return;
  }
  const net=document.getElementById('wNet').value;
  const addr=document.getElementById('wAddr').value.trim();
  const amt=parseFloat(document.getElementById('wAmt').value)||0;
  if(!addr){toast('❌ أدخل عنوان محفظتك');return;}
  if(amt<0.001){toast('❌ الحد الأدنى 0.001 AGI');return;}
  if(amt>ST.balance){toast('❌ الرصيد غير كافٍ');return;}

  ST.balance-=amt;
  addTx('📤 سحب إلى '+addr.substring(0,10)+'... ('+net+')','-'+amt.toFixed(4)+' AGI');

  // تسجيل الطلب في قائمة طلبات السحب المعلقة لمراجعة المالك
  const pending=JSON.parse(localStorage.getItem('agi_pendingW')||'[]');
  pending.unshift({
    id:'W'+Date.now(),
    user:'Eidmo11',
    network:net,
    address:addr,
    amount:amt.toFixed(4),
    status:'معلق',
    date:new Date().toLocaleString('ar-SA',{hour:'2-digit',minute:'2-digit',day:'2-digit',month:'2-digit'})
  });
  localStorage.setItem('agi_pendingW',JSON.stringify(pending.slice(0,50)));

  save();
  closeM('mWithdraw');
  toast('✅ طلب السحب أُرسل — بانتظار موافقة المالك ودفعه يدوياً');
  render();
}

function openPayModal(pkgName,amount){
  document.getElementById('payPkgName').textContent=pkgName;
  document.getElementById('payPkgAmount').textContent=amount;
  switchPayNet('bep');
  openM('mPayAd');
}
function switchPayNet(net){
  const bep=document.getElementById('payNetBep'),ton=document.getElementById('payNetTon');
  const bepBox=document.getElementById('payBepBox'),tonBox=document.getElementById('payTonBox');
  if(net==='bep'){
    bep.style.background='var(--ink)';bep.style.color='#fff';
    ton.style.background='transparent';ton.style.color='var(--muted)';
    bepBox.style.display='block';tonBox.style.display='none';
  } else {
    ton.style.background='var(--ink)';ton.style.color='#fff';
    bep.style.background='transparent';bep.style.color='var(--muted)';
    tonBox.style.display='block';bepBox.style.display='none';
  }
}

function switchNet(net){
  const bep=document.getElementById('netBep'),ton=document.getElementById('netTon');
  const bepBox=document.getElementById('bepBox'),tonBox=document.getElementById('tonBox');
  if(net==='bep'){
    bep.style.background='var(--ink)';bep.style.color='#fff';
    ton.style.background='transparent';ton.style.color='var(--muted)';
    bepBox.style.display='block';tonBox.style.display='none';
  } else {
    ton.style.background='var(--ink)';ton.style.color='#fff';
    bep.style.background='transparent';bep.style.color='var(--muted)';
    tonBox.style.display='block';bepBox.style.display='none';
  }
}
function copyAddr(addr){
  const a=addr||'0xC7FA03BAE1d361401C30AAaF20333486fBe1D6b9';
  if(a.includes('لم يتم')){toast('❌ لم يتم ضبط عنوان TON بعد');return;}
  navigator.clipboard&&navigator.clipboard.writeText(a);toast('📋 تم نسخ العنوان');
}
function getRefUrl(){return 'https://t.me/AGI_Network_bot?start='+ST.refCode;}
function copyRef(){navigator.clipboard&&navigator.clipboard.writeText(getRefUrl());toast('📋 تم نسخ رابط الإحالة الخاص بك');}

let vt;
function watchVideo(){
  document.getElementById('vo').classList.add('open');
  let t=15;document.getElementById('vt').textContent=t;
  const sk=document.getElementById('sk');sk.classList.remove('rdy');sk.style.pointerEvents='none';
  vt=setInterval(()=>{t--;document.getElementById('vt').textContent=t;
    if(t<=0){clearInterval(vt);document.getElementById('vt').textContent='✓';sk.classList.add('rdy');sk.style.pointerEvents='all';}
  },1000);
}
function closeVideo(){
  document.getElementById('vo').classList.remove('open');
  ST.balance+=0.01;save();addTx('📺 مشاهدة إعلان','+0.01 AGI');toast('🎉 +0.01 AGI');render();
}

function toggleNotif(){document.getElementById('notifToggle').classList.toggle('off');}

function doLogin(){
  const u=document.getElementById('aUser').value.trim(),p=document.getElementById('aPass').value;
  if(u==='eidmo11'&&btoa(p)===btoa('Mno112233')){
    document.getElementById('adminLogin').style.display='none';
    document.getElementById('adminPanel').style.display='block';
    document.getElementById('aErr').style.display='none';
    document.getElementById('adUsers').textContent=Math.floor(Math.random()*500+100);
    document.getElementById('adMiners').textContent=Math.floor(Math.random()*200+50);
    document.getElementById('ownerBal').textContent='$'+(ST.balance*0.3).toFixed(2);
    renderPendingWithdrawals();
    toast('👑 مرحباً بالمدير!');
  } else {document.getElementById('aErr').style.display='block';}
}
function doLogout(){
  document.getElementById('adminLogin').style.display='block';
  document.getElementById('adminPanel').style.display='none';
  document.getElementById('aUser').value='';document.getElementById('aPass').value='';
  go('profile');toast('تم الخروج');
}

function openM(id){document.getElementById(id).classList.add('open');}
function closeM(id){document.getElementById(id).classList.remove('open');}

let ttm;
function toast(msg){const e=document.getElementById('toastEl');e.textContent=msg;e.classList.add('show');clearTimeout(ttm);ttm=setTimeout(()=>e.classList.remove('show'),2800);}

render();
setInterval(render,1000);
</script>
